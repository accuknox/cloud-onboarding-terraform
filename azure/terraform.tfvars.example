# AccuKnox Tenant ID
managing_tenant_id   = "00000000-0000-0000-0000-000000000000"


# Customer Managing ID and Subscription IS
management_group_id  = "my-root-grp"
context_subscription_id     = "00000000-0000-0000-0000-000000000000"


# Visible in LightHouse
offer_name        = "AccuKnox Delegation"
offer_description = "Delegated read-only access via Lighthouse"


# AccuKnox Tokem
accuknox_verification_token = "AK-CNAPP-XXXXXX"


# Authorized Viewers
authorizations = [
  {
    principal_id           = "11111111-1111-1111-1111-111111111111"
    principal_display_name = "AccuKnox CSPM Readers"
    role_definition_id     = "acdd72a7-3385-48ef-bd42-f606fba81ae7" # Reader
  }
]


# Onboarding mode configuration
# Options: "include" or "exclude"

# Global exclusions (applies to both modes)
# excluded_subscription_ids = ["sub-to-exclude"]

mode = "include" 

# Include mode variables (use when mode = "include")
# included_management_group_ids  = ["mg-1", "mg-2"]
# include_extra_subscription_ids = ["sub-1", "sub-2"]


# Exclude mode variables (use when mode = "exclude")
# excluded_management_groups = ["mg-to-exclude"]


# Policy settings
policy_definition_name      = "Enable-Azure-Lighthouse-AccuKnox"
policy_assignment_name      = "lh-enf"
policy_assignment_location  = "eastus"
deployment_location         = "eastus"
